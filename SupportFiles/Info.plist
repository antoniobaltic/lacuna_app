	<string>lacuna needs camera access to take photos for your time capsules.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>lacuna needs microphone access to record voice notes for your time capsules.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>lacuna needs photo library access to include photos in your time capsules.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>CremeBackground</string>
