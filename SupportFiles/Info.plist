			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>antoniobaltic.embargo.capsule</string>
			</array>
		</dict>
	</array>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>
